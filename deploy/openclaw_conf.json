{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "nodes": {
      "pairing": {
        "autoApproveCidrs": ["172.30.0.10/32"]
      },
      "browser": {
        "mode": "off"
      },
      "allowCommands": [],
      "denyCommands": []
    },
    "auth": {
      "mode": "token"
    },
    "controlUi": {
      "enabled": true,
      "allowedOrigins": ["https://openclaw.local:18789"]
    },
    "tls": {
      "enabled": true,
      "autoGenerate": false,
      "certPath": "/home/node/.openclaw/gateway/tls/gateway-cert.pem",
      "keyPath": "/home/node/.openclaw/gateway/tls/gateway-key.pem"
    }
  },
  "memory": {
    "backend": "builtin"
  },
  "plugins": {
    "allow": [
      "browser",
      "feishu",
      "lobster",
      "open-prose",
      "llm-task",
      "acpx",
      "perplexity",
      "document-extract",
      "memory-core",
      "active-memory",
      "memory-wiki",
      "guidance"
    ],
    "entries": {
      "browser": {
        "enabled": true
      },
      "feishu": {
        "enabled": true
      },
      "lobster": {
        "enabled": true
      },
      "open-prose": {
        "enabled": true
      },
      "document-extract": {
        "enabled": true
      },
      "memory-core": {
        "enabled": true,
        "config": {
          "dreaming": {
            "enabled": true
          }
        }
      },
      "active-memory": {
        "enabled": true,
        "config": {
          "agents": ["steward"],
          "model": "litellm/qwen3.6-flash",
          "queryMode": "recent",
          "promptStyle": "balanced",
          "timeoutMs": 15000,
          "maxSummaryChars": 220,
          "allowedChatTypes": ["direct"],
          "logging": true,
          "persistTranscripts": true,
          "transcriptDir": "active-memory"
        }
      },
      "llm-task": {
        "enabled": true,
        "config": {
          "allowedModels": ["litellm/qwen3.6-flash"],
          "defaultProvider": "litellm",
          "defaultModel": "qwen3.6-flash"
        }
      },
      "acpx": {
        "enabled": true,
        "config": {
          "agents": {
            "copilot": {
              "command": "/usr/local/bin/coder_acp_cmd.sh"
            }
          }
        }
      },
      "perplexity": {
        "enabled": true,
        "config": {
          "webSearch": {
            "baseUrl": "http://litellm-gateway:8081/v1",
            "model": "qwen3.6-flash-search"
          }
        }
      },
      "guidance": {
        "enabled": true,
        "config": {
          "rootDir": "/workspaces/shared",
          "files": ["AGENTS.md", "TOOLS.md", "SOUL.md", "USER.md"]
        }
      },
      "memory-wiki": {
        "enabled": true,
        "config": {
          "vaultMode": "bridge",
          "vault": {
            "path": "~/.openclaw/memory-wiki",
            "renderMode": "obsidian"
          },
          "obsidian": {
            "enabled": true,
            "useOfficialCli": true,
            "vaultName": "OpenClaw Wiki",
            "openAfterWrites": false
          },
          "bridge": {
            "enabled": true,
            "readMemoryArtifacts": true,
            "indexDreamReports": false,
            "indexDailyNotes": true,
            "indexMemoryRoot": true,
            "followMemoryEvents": false
          },
          "ingest": {
            "autoCompile": true,
            "maxConcurrentJobs": 1,
            "allowUrlIngest": true
          },
          "search": {
            "backend": "shared",
            "corpus": "all"
          },
          "context": {
            "includeCompiledDigestPrompt": false
          },
          "render": {
            "preserveHumanBlocks": true,
            "createBacklinks": true,
            "createDashboards": true
          }
        }
      }
    },
    "slots": {
      "memory": "memory-core",
      "contextEngine": "guidance"
    }
  },
  "secrets": {
    "providers": {
      "default": { "source": "env" },
      "vault": {
        "source": "exec",
        "command": "/usr/local/bin/keepassxc-vault.sh",
        "args": [
          "/run/openclaw-secrets/openclaw-secrets.kdbx",
          "/run/openclaw-secrets/openclaw-secrets.pass"
        ],
        "passEnv": [],
        "jsonOnly": false
      }
    },
    "defaults": {
      "env": "default",
      "exec": "vault"
    },
    "resolution": {
      "maxProviderConcurrency": 4,
      "maxRefsPerProvider": 512,
      "maxBatchBytes": 262144
    }
  },
  "commitments": {
    "enabled": true,
    "maxPerDay": 3
  },
  "skills": {
    "allowBundled": [
      "healthcheck",
      "node-connect",
      "session-logs",
      "clawhub",
      "skill-creator",
      "taskflow",
      "weather",
      "obsidian"
    ],
    "load": {
      "extraDirs": ["/workspaces/shared/skills"],
      "watch": true,
      "watchDebounceMs": 250
    },
    "install": {
      "preferBrew": true,
      "nodeManager": "npm"
    }
  },
  "tools": {
    "web": {
      "search": {
        "enabled": true,
        "provider": "perplexity"
      }
    },
    "elevated": {
      "enabled": true,
      "allowFrom": {
        "feishu": [
          "ou_4290ea171c15d637f2b77fbe49837677",
          "ou_0498da08e35c3f356cec322fe2896986",
          "ou_8b8d96a3c236372093e2717c879ccaad"
        ]
      }
    },
    "exec": {
      "host": "node",
      "node": "exec_node",
      "security": "full",
      "ask": "off"
    },
    "fs": {
      "workspaceOnly": true
    }
  },
  "acp": {
    "enabled": true,
    "dispatch": {
      "enabled": true
    },
    "backend": "acpx",
    "defaultAgent": "copilot",
    "allowedAgents": ["copilot"],
    "maxConcurrentSessions": 8,
    "stream": {
      "coalesceIdleMs": 300,
      "maxChunkChars": 1200
    },
    "runtime": {
      "ttlMinutes": 120
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "text": true,
    "bash": true,
    "config": true,
    "restart": true,
    "plugins": true,
    "allowFrom": {
      "feishu": [
        "ou_4290ea171c15d637f2b77fbe49837677",
        "ou_0498da08e35c3f356cec322fe2896986",
        "ou_8b8d96a3c236372093e2717c879ccaad"
      ]
    }
  },
  "browser": {
    "enabled": true,
    "evaluateEnabled": true,
    "headless": false,
    "noSandbox": true,
    "defaultProfile": "host-chrome",
    "profiles": {
      "host-chrome": {
        "cdpUrl": "http://127.0.0.1:9222",
        "color": "#00AA00"
      }
    },
    "ssrfPolicy": {
      "allowedHostnames": ["localhost", "127.0.0.1"]
    }
  },
  "session": {
    "dmScope": "per-peer",
    "maintenance": {
      "mode": "enforce",
      "pruneAfter": "30d",
      "maxEntries": 500
    },
    "reset": {
      "mode": "daily",
      "atHour": 4,
      "idleMinutes": 120
    }
  },
  "agents": {
    "defaults": {
      "skipBootstrap": true,
      "timeoutSeconds": 3600,
      "maxConcurrent": 4,
      "verboseDefault": "on",
      "reasoningDefault": "on",
      "subagents": {
        "runTimeoutSeconds": 1800,
        "maxConcurrent": 8,
        "maxChildrenPerAgent": 4,
        "maxSpawnDepth": 1
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "20m"
      },
      "memorySearch": {
        "enabled": true,
        "provider": "openai",
        "model": "text-embedding-v4",
        "fallback": "none",
        "query": {
          "hybrid": {
            "mmr": {
              "enabled": true
            },
            "temporalDecay": {
              "enabled": true
            }
          }
        }
      },
      "compaction": {
        "reserveTokensFloor": 20000,
        "model": "litellm/qwen3.6-flash",
        "notifyUser": true,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 10000,
          "prompt": "Write down: - info and preference about the user\n- correction to my behavior by user\n- subjects or tasks with multiple interactions\n -Other you think important to remember\nBe concise but informative.",
          "systemPrompt": "This chat is about to end. Summarize them in a few words and write them down."
        }
      },
      "elevatedDefault": "full",
      "skills": []
    },
    "list": [
      {
        "id": "steward",
        "default": true,
        "name": "Adam",
        "workspace": "/workspaces/steward",
        "agentDir": "~/.openclaw/agents/steward/agent",
        "model": "litellm/qwen3.6-plus",
        "subagents": {
          "allowAgents": ["*"]
        },
        "tools": {
          "profile": "full",
          "alsoAllow": ["lobster", "llm-task"],
          "deny": [
            "group:memory-wiki",
            "canvas",
            "image_generate",
            "music_generate",
            "video_generate"
          ]
        },
        "skills": [
          "clawhub",
          "skill-creator",
          "skill-vetter",
          "prose",
          "taskflow",
          "healthcheck",
          "node-connect",
          "session-logs",
          "weather",
          "obsidian",
          "wiki-create"
        ]
      },
      {
        "id": "coder",
        "name": "Ape",
        "workspace": "/workspaces/coder",
        "runtime": {
          "type": "acp",
          "acp": {
            "agent": "copilot",
            "backend": "acpx",
            "mode": "persistent",
            "cwd": "/projects"
          }
        }
      },
      {
        "id": "planner",
        "name": "Fox",
        "workspace": "/workspaces/planner",
        "agentDir": "~/.openclaw/agents/planner/agent",
        "model": "litellm/qwen3.6-flash",
        "subagents": {
          "allowAgents": ["crawler"]
        },
        "tools": {
          "profile": "minimal",
          "alsoAllow": ["group:fs", "group:sessions", "group:memory", "group:agents", "exec"]
        },
        "skills": ["wiki-create", "weather"]
      },
      {
        "id": "crawler",
        "name": "Spider",
        "workspace": "/workspaces/crawler",
        "agentDir": "~/.openclaw/agents/crawler/agent",
        "model": "litellm/qwen3.6-flash",
        "subagents": {
          "allowAgents": []
        },
        "tools": {
          "profile": "minimal",
          "alsoAllow": ["group:fs", "group:web", "browser", "exec"]
        },
        "skills": ["browser-automation", "wiki-create", "ctrip-travel-search"]
      }
    ]
  },
  "bindings": [
    {
      "agentId": "steward",
      "match": {
        "channel": "feishu",
        "accountId": "steward"
      }
    },
    {
      "agentId": "coder",
      "type": "acp",
      "match": {
        "channel": "feishu",
        "accountId": "coder",
        "peer": {
          "kind": "dm",
          "id": "ou_8b8d96a3c236372093e2717c879ccaad"
        }
      }
    },
    {
      "agentId": "planner",
      "match": {
        "channel": "feishu",
        "accountId": "planner"
      }
    }
  ],
  "messages": {
    "queue": {
      "mode": "collect",
      "debounceMs": 1000,
      "cap": 20,
      "drop": "summarize"
    }
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "connectionMode": "websocket",
      "domain": "feishu",
      "dmPolicy": "allowlist",
      "groupPolicy": "allowlist",
      "allowFrom": [
        "ou_4290ea171c15d637f2b77fbe49837677",
        "ou_0498da08e35c3f356cec322fe2896986",
        "ou_8b8d96a3c236372093e2717c879ccaad"
      ],
      "groupAllowFrom": ["oc_63168d210b0475e95d43d7341b97af7c"],
      "accounts": {
        "steward": {
          "appId": "${FEISHU_APP_ID_STEWARD}",
          "appSecret": {
            "source": "exec",
            "provider": "vault",
            "id": "feishu/stewardAppSecret"
          }
        },
        "coder": {
          "appId": "${FEISHU_APP_ID_CODER}",
          "appSecret": {
            "source": "exec",
            "provider": "vault",
            "id": "feishu/coderAppSecret"
          }
        },
        "planner": {
          "appId": "${FEISHU_APP_ID_PLANNER}",
          "appSecret": {
            "source": "exec",
            "provider": "vault",
            "id": "feishu/plannerAppSecret"
          }
        }
      }
    }
  },
  "models": {
    "providers": {
      "litellm": {
        "baseUrl": "http://litellm-gateway:8081/v1",
        "apiKey": {
          "source": "exec",
          "provider": "vault",
          "id": "litellm/apiKey"
        },
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen3-max",
            "name": "Qwen3 Max",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 262144,
            "maxTokens": 32768
          },
          {
            "id": "qwen3.6-plus",
            "name": "qwen3.6 Plus",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 1000000,
            "maxTokens": 65536
          },
          {
            "id": "qwen3.6-flash",
            "name": "qwen3.6 Flash",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 1000000,
            "maxTokens": 65536
          },
          {
            "id": "kimi-k2.5",
            "name": "Kimi K2.5",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 262144,
            "maxTokens": 258048
          }
        ]
      },
      "openai": {
        "baseUrl": "http://litellm-gateway:8081/v1",
        "apiKey": {
          "source": "exec",
          "provider": "vault",
          "id": "litellm/apiKey"
        },
        "models": [
          {
            "id": "text-embedding-v4",
            "name": "Text Embedding V4",
            "input": ["text"],
            "maxTokens": 81920
          }
        ]
      }
    }
  }
}
