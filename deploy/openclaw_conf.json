{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "auth": {
      "mode": "token"
    },
    "controlUi": {
      "enabled": true,
      "allowedOrigins": [
        "https://my-openclaw.local:18789"
      ]
    },
    "tls": {
      "enabled": true,
      "autoGenerate": true
    }
  },
  "logging": {
    "level": "info",
    "redactSensitive": "tools"
  },
  "agents": {
    "defaults": {
      "maxConcurrent": 1,
      "subagents": {
        "maxConcurrent": 2
      },
      "workspace": "~/.openclaw/workspace",
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "session": {
    "mainKey": "main"
  },
  "diagnostics": {
    "enabled": true
  }
}
