{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "auth": {
      "mode": "token"
    },
    "controlUi": {
      "enabled": true,
      "allowedOrigins": ["https://openclaw.local:18789"]
    },
    "tls": {
      "enabled": true,
      "autoGenerate": true
    }
  },
  "memory": {
    "backend": "qmd"
  },
  "plugins": {
    "allow": ["browser", "feishu", "lobster", "open-prose", "llm-task", "guidance", "acpx"],
    "entries": {
      "feishu": {
        "enabled": true
      },
      "lobster": {
        "enabled": true
      },
      "open-prose": {
        "enabled": true
      },
      "llm-task": {
        "enabled": true,
        "config": {
          "allowedModels": ["litellm/qwen3.6-flash"],
          "defaultProvider": "litellm",
          "defaultModel": "qwen3.6-flash"
        }
      },
      "acpx": {
        "enabled": true,
        "config": {
          "agents": {
            "copilot": {
              "command": "/usr/local/bin/custom_acpx.sh"
            }
          }
        }
      },
      "perplexity": {
        "enabled": true,
        "config": {
          "webSearch": {
            "baseUrl": "http://litellm-gateway:8081/v1",
            "model": "qwen3.6-flash-search"
          }
        }
      },
      "guidance": {
        "config": {
          "files": [
            "workspace-shared/AGENTS.md",
            "workspace-shared/TOOLS.md",
            "workspace-shared/SOUL.md",
            "workspace-shared/USER.md"
          ]
        }
      }
    },
    "slots": {
      "contextEngine": "public-guidance"
    }
  },
  "skills": {
    "allowBundled": [
      "healthcheck",
      "node-connect",
      "session-logs",

      "clawhub",
      "skill-creator",
      "taskflow",

      "weather"
    ],
    "load": {
      "extraDirs": ["~/.openclaw/workspace-shared/skills"],
      "watch": true,
      "watchDebounceMs": 250
    },
    "install": {
      "preferBrew": true,
      "nodeManager": "npm"
    },
    "entries": {
      "keepassxc": {
        "enabled": true,
        "env": {
          "KEEPASS_DB_PASS": "${AGENT_SECRET_DB_PASSWORD}"
        },
        "config": {
          "dbPath": "~/.openclaw/workspace-shared/secrets.kdbx"
        }
      }
    }
  },
  "tools": {
    "web": {
      "search": {
        "enabled": true,
        "provider": "perplexity"
      }
    },
    "elevated": {
      "enabled": true,
      "allowFrom": {
        "feishu": [
          "ou_4290ea171c15d637f2b77fbe49837677",
          "ou_0498da08e35c3f356cec322fe2896986",
          "ou_8b8d96a3c236372093e2717c879ccaad"
        ]
      }
    },
    "exec": {
      "host": "gateway",
      "security": "full",
      "ask": "off"
    }
  },
  "acp": {
    "enabled": true,
    "dispatch": { "enabled": true },
    "backend": "acpx",
    "defaultAgent": "copilot",
    "allowedAgents": ["copilot"],
    "maxConcurrentSessions": 8,
    "stream": {
      "coalesceIdleMs": 300,
      "maxChunkChars": 1200
    },
    "runtime": {
      "ttlMinutes": 120
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "text": true,
    "bash": true,
    "config": true,
    "restart": true,
    "plugins": true,
    "allowFrom": {
      "feishu": [
        "ou_4290ea171c15d637f2b77fbe49837677",
        "ou_0498da08e35c3f356cec322fe2896986",
        "ou_8b8d96a3c236372093e2717c879ccaad"
      ]
    }
  },
  "browser": {
    "enabled": true,
    "evaluateEnabled": true,
    "executablePath": "${CHROMIUM_EXECUTABLE_PATH}",
    "headless": false,
    "noSandbox": true,
    "defaultProfile": "host-chrome",
    "profiles": {
      "host-chrome": {
        "cdpUrl": "http://127.0.0.1:9222",
        "color": "#00AA00"
      }
    },
    "ssrfPolicy": {
      "allowedHostnames": ["localhost", "127.0.0.1"]
    }
  },
  "session": {
    "dmScope": "per-peer",
    "maintenance": {
      "mode": "enforce",
      "pruneAfter": "30d",
      "maxEntries": 500
    },
    "reset": {
      "mode": "daily",
      "atHour": 4,
      "idleMinutes": 120
    }
  },
  "agents": {
    "defaults": {
      "skipBootstrap": true,
      "timeoutSeconds": 3600,
      "maxConcurrent": 4,
      "verboseDefault": "on",
      "subagents": {
        "runTimeoutSeconds": 1800,
        "maxConcurrent": 8,
        "maxChildrenPerAgent": 4,
        "maxSpawnDepth": 1
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "20m"
      },
      "compaction": {
        "reserveTokensFloor": 20000,
        "model": "litellm/qwen3.6-plus",
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 10000,
          "prompt": "Write user's preferences, habits you just learned to MEMORY.md and other import facts to memory/YYYY-MM-DD.md. Reply with NO_REPLY if nothing to store.",
          "systemPrompt": "This chat is about to end. Summarize them in a few words and write them down."
        }
      },
      "elevatedDefault": "full",
      "skills": []
    },
    "list": [
      {
        "id": "steward",
        "default": true,
        "name": "Adam",
        "workspace": "~/.openclaw/workspace-steward",
        "agentDir": "~/.openclaw/agents/steward/agent",
        "model": "litellm/qwen3.6-plus",
        "reasoningDefault": "on",
        "subagents": {
          "allowAgents": ["*"]
        },
        "tools": {
          "profile": "full",
          "alsoAllow": ["lobster", "llm-task"]
        },
        "skills": [
          "clawhub",
          "skill-creator",
          "skill-vetter",
          "prose",
          "taskflow",
          "healthcheck",
          "node-connect",
          "keepassxc",
          "session-logs",
          "weather"
        ]
      },
      {
        "id": "coder",
        "name": "Ape",
        "workspace": "~/.openclaw/workspace-coder",
        "runtime": {
          "type": "acp",
          "acp": {
            "agent": "copilot",
            "backend": "acpx",
            "mode": "persistent",
            "cwd": "/projects"
          }
        }
      },
      {
        "id": "planner",
        "name": "Fox",
        "workspace": "~/.openclaw/workspace-planner",
        "agentDir": "~/.openclaw/agents/planner/agent",
        "model": "litellm/qwen3.6-flash",
        "subagents": {
          "allowAgents": []
        },
        "tools": {
          "profile": "full"
        },
        "skills": ["ctrip-travel-search"]
      }
    ]
  },
  "bindings": [
    {
      "agentId": "steward",
      "match": {
        "channel": "feishu",
        "accountId": "steward"
      }
    },
    {
      "agentId": "coder",
      "type": "acp",
      "match": {
        "channel": "feishu",
        "accountId": "coder",
        "peer": { "kind": "dm", "id": "ou_8b8d96a3c236372093e2717c879ccaad" }
      }
    },
    {
      "agentId": "planner",
      "match": {
        "channel": "feishu",
        "accountId": "planner"
      }
    }
  ],
  "messages": {
    "queue": {
      "mode": "collect",
      "debounceMs": 1000,
      "cap": 20,
      "drop": "summarize"
    }
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "connectionMode": "websocket",
      "domain": "feishu",
      "dmPolicy": "allowlist",
      "groupPolicy": "allowlist",
      "allowFrom": [
        "ou_4290ea171c15d637f2b77fbe49837677",
        "ou_0498da08e35c3f356cec322fe2896986",
        "ou_8b8d96a3c236372093e2717c879ccaad"
      ],
      "groupAllowFrom": ["oc_63168d210b0475e95d43d7341b97af7c"],
      "accounts": {
        "steward": {
          "appId": "${FEISHU_APP_ID_STEWARD}",
          "appSecret": "${FEISHU_APP_SECRET_STEWARD}"
        },
        "coder": {
          "appId": "${FEISHU_APP_ID_CODER}",
          "appSecret": "${FEISHU_APP_SECRET_CODER}"
        },
        "planner": {
          "appId": "${FEISHU_APP_ID_PLANNER}",
          "appSecret": "${FEISHU_APP_SECRET_PLANNER}"
        }
      }
    }
  },
  "models": {
    "providers": {
      "litellm": {
        "baseUrl": "http://litellm-gateway:8081/v1",
        "apiKey": "${LITELLM_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen3-max",
            "name": "Qwen3 Max",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 262144,
            "maxTokens": 32768
          },
          {
            "id": "qwen3.6-plus",
            "name": "qwen3.6 Plus",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 1000000,
            "maxTokens": 65536
          },
          {
            "id": "qwen3.6-flash",
            "name": "qwen3.6 Flash",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 1000000,
            "maxTokens": 65536
          },
          {
            "id": "kimi-k2.5",
            "name": "Kimi K2.5",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 262144,
            "maxTokens": 258048
          }
        ]
      }
    }
  }
}
