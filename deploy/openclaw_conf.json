{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "auth": {
      "mode": "token"
    },
    "controlUi": {
      "enabled": true,
      "allowedOrigins": [
        "https://openclaw.local:18789"
      ]
    },
    "tls": {
      "enabled": true,
      "autoGenerate": true
    }
  },
  "logging": {
    "level": "info",
    "redactSensitive": "tools"
  },
  "agents": {
    "defaults": {
      "maxConcurrent": 1,
      "subagents": {
        "maxConcurrent": 2
      },
      "workspace": "~/.openclaw/workspace",
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "session": {
    "mainKey": "main"
  },
  "diagnostics": {
    "enabled": true
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "appId": "${FEISHU_APP_ID}",
      "appSecret": "${FEISHU_APP_SECRET}",
      "connectionMode": "websocket",
      "domain": "feishu",
      "dmPolicy": "allowlist",
      "allowFrom": ["ou_16d3bb304424a58d95a9bff5fd71cbe1"],
      "groupPolicy": "allowlist",
      "groupAllowFrom": ["oc_bb3e21ce2de29f2c97e370a20c45f492"]
    }
  }
}
